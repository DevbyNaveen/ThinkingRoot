# The desktop UI has its own src/lib/ — re-include it (the global
# `lib/` rule above is for Python virtualenvs).
!apps/thinkingroot-desktop/ui/src/lib/
!apps/thinkingroot-desktop/ui/src/lib/**

# Node
node_modules/

# Desktop app build outputs (apps/thinkingroot-desktop/)
apps/thinkingroot-desktop/ui/dist/
apps/thinkingroot-desktop/src-tauri/target/
# Staged sidecar binaries — built fresh per machine via build.rs;
# the .gitkeep stub keeps the directory present in the tree.
apps/thinkingroot-desktop/src-tauri/binaries/*
!apps/thinkingroot-desktop/src-tauri/binaries/.gitkeep

