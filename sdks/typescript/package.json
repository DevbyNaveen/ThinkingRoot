{
  "name": "thinkingroot",
  "version": "0.9.1",
  "description": "TypeScript SDK for ThinkingRoot — the secondary brain for AI agents.",
  "license": "MIT",
  "homepage": "https://thinkingroot.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevbyNaveen/thinkingroot.git",
    "directory": "sdks/typescript"
  },
  "keywords": [
    "ai",
    "agent",
    "knowledge-graph",
    "memory",
    "mcp",
    "rag",
    "thinkingroot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cortex": {
      "import": "./dist/cortex.js",
      "types": "./dist/cortex.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
